{
  "manifest_version": 3,
  "name": "SCZip",
  "version": "0.1.1",
  "description": "ダウンロード許可済みのSoundCloud楽曲のジャケット画像と音声をZIPで保存します",
  "permissions": ["activeTab", "contextMenus", "scripting", "webRequest", "storage", "downloads", "offscreen"],
  "host_permissions": [
    "https://soundcloud.com/*",
    "https://api-v2.soundcloud.com/*",
    "https://*.sndcdn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "image/icon.png",
    "48": "image/icon.png",
    "128": "image/icon.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://soundcloud.com/*"],
      "js": ["jszip.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SoundCloud Zip抽出"
  }
}
